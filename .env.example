# Copy this file to .env and fill in the values.

# ── Auth ────────────────────────────────────────────────────────────────────
PASSWORD=changeme

# ── User identity ───────────────────────────────────────────────────────────
# Match your host UID/GID to avoid volume permission issues.
# On Linux/Mac: run `id -u` and `id -g` to find your values.
PUID=1000
PGID=1000

# ── Timezone ────────────────────────────────────────────────────────────────
TZ=Asia/Singapore

# ── Data persistence ────────────────────────────────────────────────────────
# Host path for the home directory inside the container (/home/coder).
DATA_DIR=./data/home

# Host path mounted as /home/coder/dev/projects (your code).
# Set to an absolute path on the host, e.g. /Users/you/dev/projects
PROJECTS_DIR=./data/projects

# ── Network ─────────────────────────────────────────────────────────────────
# Port exposed on the host (standalone mode, no nginx overlay).
PORT=8929

# Name of the external Docker network (nginx overlay only).
# NGINX_NETWORK=nginx

# ── HTTPS ───────────────────────────────────────────────────────────────────
# Set to 1 to enable HTTPS with an auto-generated self-signed certificate.
# Browser will show a security warning — click "Advanced" > "Proceed" to continue.
HTTPS=0

# ── Behaviour ───────────────────────────────────────────────────────────────
# Set to 0 to skip tool auto-updates on every container start.
UPDATE_ON_START=1
